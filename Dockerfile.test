# Test image for Rune's Docker-based test harness (see docker-compose.yml).
#
# Per project policy the Go test suite runs inside this container, never on the
# host (CONTRIBUTING.md). docker-compose bind-mounts the repo at /src and caches
# modules/build output in named volumes, so this image only needs the toolchain.
#
#   docker-compose run --rm test                      # full suite: go test ./...
#   docker-compose run --rm test go test ./test/docs/...   # docs verification
#   docker-compose run --rm -e CGO_ENABLED=1 test go test -race ./...
#
# It mirrors the production Dockerfile's builder base (golang:1.25-bookworm),
# whose gcc satisfies the race detector's CGO requirement. CGO defaults to off
# to match the shipped artifact; -race runs override it via CGO_ENABLED=1.
ARG GO_VERSION=1.25

FROM golang:${GO_VERSION}-bookworm
WORKDIR /src
ENV CGO_ENABLED=0
