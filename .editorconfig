root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_style = tab

[*.{yml,yaml,json,md,toml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

# Rune task files use significant indentation; keep it spaces and explicit.
[{Runefile,*.rune}]
indent_style = space
indent_size = 4

# Markdown: don't strip trailing whitespace (two trailing spaces = hard break).
[*.md]
trim_trailing_whitespace = false
