# [parallel] runs a task's independent dependencies concurrently (bounded).

# lint, test, and typecheck have no dependencies on each other, so they run
# concurrently; `checks` runs after all three finish.
[parallel]
checks: lint test typecheck
    @echo "all checks passed"

lint:
    @echo "lint"

test:
    @echo "test"

typecheck:
    @echo "typecheck"
