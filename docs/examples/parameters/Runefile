# Parameters: defaulted, required, and variadic — interpolated with {{ }}.

# Defaulted parameter (rune greet  /  rune greet Ada).
greet name="world":
    @echo "hello {{name}}"

# Required parameter (rune deploy prod).
deploy env:
    @echo "deploying to {{env}}"

# Variadic, one-or-more (rune test ./... ./cmd/...).
test +packages:
    @echo "go test {{packages}}"
