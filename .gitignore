# Rune build & cache artifacts
/dist/
.rune/
# Stray host binary from `go build ./cmd/rune` without -o (real output is dist/rune).
/rune
/rune.exe

# Go
*.test
*.out
coverage.txt

# Not a Go test binary: the docker-compose test image (matched by *.test above).
!Dockerfile.test

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# ai
.claude/*
# …but the release-guru skill is a committed, reviewable artifact. Re-including a
# nested path requires un-ignoring each parent dir first (git can't descend into an
# excluded dir), then re-ignoring the other (symlinked) skills.
!.claude/skills
.claude/skills/*
!.claude/skills/release-guru
!.claude/skills/release-guru/**
.agents/*
.specify/*
.help
# …but the project constitution is a committed, reviewable artifact.
!.specify/memory/
!.specify/memory/constitution.md
skills-lock.json
