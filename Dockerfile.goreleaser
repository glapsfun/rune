# Release image built by GoReleaser. Unlike the top-level Dockerfile (which compiles
# from source for `rune docker`), this one COPYs the already-built, version-stamped
# binary that GoReleaser places in the build context — no recompile, and the image
# binary is byte-identical to the published archive. OCI labels are applied via
# GoReleaser build_flag_templates (see .goreleaser.yaml).
FROM gcr.io/distroless/static-debian12:nonroot
COPY rune /rune
WORKDIR /work
ENTRYPOINT ["/rune"]
